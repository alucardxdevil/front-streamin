# ─── Variables de entorno del Frontend ───────────────────────────────────────
#
# Archivos de entorno disponibles:
#   .env.development     → Desarrollo local (npm start) — se sube al repo
#   .env.production      → Producción (npm run build) — se sube al repo
#   .env.development.local → Override local de desarrollo — NO se sube al repo
#   .env.production.local  → Override local de producción — NO se sube al repo
#
# IMPORTANTE: En Cloudflare Pages, configura estas variables en:
#   Settings → Environment Variables → Production
# ─────────────────────────────────────────────────────────────────────────────

# URL base del backend (sin /api al final)
# Producción: URL HTTPS del backend (Cloudflare Tunnel o dominio con SSL)
# Desarrollo: http://localhost:5000
REACT_APP_API_URL=http://localhost:5000

# Entorno de la aplicación
REACT_APP_ENV=development

# Evita que react-scripts trate warnings como errores en CI
CI=false
