# ─── Variables de entorno del Frontend ───────────────────────────────────────
#
# Copia este archivo como .env.local para desarrollo local
# o configura estas variables en Cloudflare Pages para producción.
#
# IMPORTANTE: En Cloudflare Pages, configura estas variables en:
#   Settings → Environment Variables → Production
# ─────────────────────────────────────────────────────────────────────────────

# URL base del backend (sin /api al final)
# Producción: http://89.167.94.4
# Desarrollo: http://localhost:5000
REACT_APP_API_URL=http://89.167.94.4

# Entorno de la aplicación
REACT_APP_ENV=production
