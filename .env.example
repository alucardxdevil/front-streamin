# =============================================================================
# teleprt — Frontend (Vite)
# =============================================================================
#
# Desarrollo local:  .env.development  → npm run dev
# Build producción:  .env.production   → npm run build
#
# Cloudflare Pages → Settings → Environment Variables → Production:
#   VITE_API_URL  = https://api.teleprt.com   ← NO usar api.stream-in.com
#   VITE_SITE_URL = https://teleprt.com
#   VITE_ENV      = production
#   VITE_ENV      = production
#
# IMPORTANTE: Vite solo expone variables con prefijo VITE_
#
# Google Sign-In (Firebase): en Firebase Console → Authentication → Authorized domains
# agregar teleprt.com, www.teleprt.com y localhost.
# =============================================================================

# --- Desarrollo (valores por defecto en .env.development) ---
VITE_API_URL=http://localhost:5000
VITE_SITE_URL=http://localhost:3000
VITE_ENV=development

# --- Producción (valores en .env.production) ---
# VITE_API_URL=https://api.teleprt.com
# VITE_SITE_URL=https://teleprt.com
# VITE_ENV=production
