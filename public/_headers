# Cloudflare Pages — Custom Headers

# Seguridad global
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Assets estáticos: cache inmutable (CRA genera hashes en los nombres)
/static/*
  Cache-Control: public, max-age=31536000, immutable

# index.html: no cachear (la SPA siempre debe validar)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Rutas dinámicas de video y perfil: Vary por User-Agent
# (crawlers reciben HTML diferente que usuarios normales)
/video/*
  Vary: User-Agent
  Cache-Control: public, max-age=0, must-revalidate

/profileUser/*
  Vary: User-Agent
  Cache-Control: public, max-age=0, must-revalidate

# robots.txt y sitemap: cache corto
/robots.txt
  Cache-Control: public, max-age=86400

# Imágenes públicas: cache largo
/logo-pest.jpg
  Cache-Control: public, max-age=604800
