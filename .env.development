# ─── Variables de entorno para DESARROLLO LOCAL (Vite) ───────────────────────
# Este archivo se carga con: npm run dev / npm start
# ─────────────────────────────────────────────────────────────────────────────

# URL base del backend (sin /api). El proxy de Vite reenvía /api → esta URL.
VITE_API_URL=http://localhost:5000

# URL pública del sitio (SEO)
VITE_SITE_URL=http://localhost:3000

VITE_ENV=development
